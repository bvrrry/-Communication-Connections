    <!-- Services Section -->
    <section class="section">
        <div class="container">
            <div class="services-grid">
                <!-- Speech & Articulation -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">🗣️</div>
                            <div>
                                <h2>Speech & Articulation</h2>
                                <p class="service-subtitle">Clear speech sound production</p>
                            </div>
                        </div>
                        <p class="service-description">
                            We help children develop clear, intelligible speech so they can be understood by family, friends, and teachers. Our therapy targets specific speech sounds that may be delayed or disordered, using play-based and evidence-based techniques.
                        </p>
                        <ul class="service-list">
                            <li>Assessment of speech sound development</li>
                            <li>Treatment of articulation disorders</li>
                            <li>Phonological processing therapy</li>
                            <li>Childhood apraxia of speech intervention</li>
                            <li>Parent coaching and home practice strategies</li>
                        </ul>
                    </div>
                </div>

                <!-- Language Development -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">📚</div>
                            <div>
                                <h2>Language Development</h2>
                                <p class="service-subtitle">Understanding and using language</p>
                            </div>
                        </div>
                        <p class="service-description">
                            Language skills are fundamental for learning, social interaction, and academic success. We support children in developing both their understanding (receptive language) and use (expressive language) of words, sentences, and concepts.
                        </p>
                        <ul class="service-list">
                            <li>Vocabulary building and word learning</li>
                            <li>Grammar and sentence structure development</li>
                            <li>Following directions and comprehension skills</li>
                            <li>Narrative and storytelling abilities</li>
                            <li>Concept development (colors, numbers, time, etc.)</li>
                        </ul>
                    </div>
                </div>

                <!-- Literacy Support -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">✍️</div>
                            <div>
                                <h2>Literacy & Reading Support</h2>
                                <p class="service-subtitle">Building foundations for reading and writing</p>
                            </div>
                        </div>
                        <p class="service-description">
                            Strong literacy skills begin with solid language and phonological awareness. We work on the building blocks of reading and writing, supporting children who are at risk of or experiencing literacy difficulties.
                        </p>
                        <ul class="service-list">
                            <li>Phonological awareness (rhyming, sound blending)</li>
                            <li>Letter-sound knowledge and phonics</li>
                            <li>Reading comprehension strategies</li>
                            <li>Written language and spelling support</li>
                            <li>Support for dyslexia and reading disorders</li>
                        </ul>
                    </div>
                </div>

                <!-- Early Intervention -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">👶</div>
                            <div>
                                <h2>Early Intervention (0-5 years)</h2>
                                <p class="service-subtitle">Supporting communication from the start</p>
                            </div>
                        </div>
                        <p class="service-description">
                            The early years are critical for communication development. We provide assessment and therapy for babies, toddlers, and preschoolers who may be late talkers or showing early signs of communication difficulties.
                        </p>
                        <ul class="service-list">
                            <li>Late talking and language delay support</li>
                            <li>Play skills and early interaction</li>
                            <li>Pre-linguistic communication development</li>
                            <li>Transition to preschool support</li>
                            <li>Parent-implemented intervention strategies</li>
                        </ul>
                    </div>
                </div>

                <!-- Social Communication -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">🤝</div>
                            <div>
                                <h2>Social Communication</h2>
                                <p class="service-subtitle">Building friendships and social skills</p>
                            </div>
                        </div>
                        <p class="service-description">
                            Social communication skills help children make friends, work in groups, and navigate social situations. We support children who struggle with pragmatic language, perspective-taking, and social interaction.
                        </p>
                        <ul class="service-list">
                            <li>Conversational skills and turn-taking</li>
                            <li>Understanding and using non-verbal communication</li>
                            <li>Perspective-taking and theory of mind</li>
                            <li>Social problem-solving strategies</li>
                            <li>Support for children with autism spectrum disorder</li>
                        </ul>
                    </div>
                </div>

                <!-- Feeding & Swallowing -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">🍽️</div>
                            <div>
                                <h2>Feeding & Swallowing</h2>
                                <p class="service-subtitle">Safe and enjoyable eating experiences</p>
                            </div>
                        </div>
                        <p class="service-description">
                            Feeding difficulties can impact nutrition, growth, and family mealtimes. We assess and treat oral motor skills, sensory feeding challenges, and swallowing difficulties to support safe and positive eating.
                        </p>
                        <ul class="service-list">
                            <li>Oral motor skill development</li>
                            <li>Sensory-based feeding challenges</li>
                            <li>Picky eating and food selectivity</li>
                            <li>Transitioning to solid foods</li>
                            <li>Mealtime behavior strategies</li>
                        </ul>
                    </div>
                </div>

                <!-- AAC -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">💬</div>
                            <div>
                                <h2>AAC & Alternative Communication</h2>
                                <p class="service-subtitle">Every child deserves a voice</p>
                            </div>
                        </div>
                        <p class="service-description">
                            For children with complex communication needs, we provide assessment and support for augmentative and alternative communication (AAC) systems including communication devices, apps, and visual supports.
                        </p>
                        <ul class="service-list">
                            <li>AAC assessment and system selection</li>
                            <li>Communication device programming and training</li>
                            <li>Visual supports (PECS, core boards, schedules)</li>
                            <li>Partner training for families and educators</li>
                            <li>Ongoing AAC implementation support</li>
                        </ul>
                    </div>
                </div>

                <!-- School Support -->
                <div class="service-card">
                    <div class="service-content">
                        <div class="service-header">
                            <div class="service-icon">🎓</div>
                            <div>
                                <h2>School Readiness & Support</h2>
                                <p class="service-subtitle">Preparing for academic success</p>
                            </div>
                        </div>
                        <p class="service-description">
                            Starting school is a big transition. We help children develop the communication, language, and literacy skills needed for kindergarten and beyond, and provide ongoing support for school-aged children.
                        </p>
                        <ul class="service-list">
                            <li>Pre-school language and literacy screening</li>
                            <li>School readiness skill development</li>
                            <li>Classroom language and curriculum support</li>
                            <li>Collaboration with teachers and schools</li>
                            <li>IEP and learning support planning</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
